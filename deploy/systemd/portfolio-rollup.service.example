[Unit]
Description=Portfolio analytics daily rollup
Wants=portfolio-analytics.service

[Service]
Type=oneshot
User=portfolio
Group=portfolio
WorkingDirectory=/srv/portfolio/server
Environment=NODE_ENV=production
EnvironmentFile=/srv/portfolio/server/.env
ExecStart=/usr/bin/npm run rollup
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/srv/portfolio/server/data
