# portfolio-analytics — copy to `.env` (gitignored).
# Production refuses to start until ADMIN_PASSWORD is set; dev accepts an
# empty password and logs a loud warning so contributors notice.

# NODE_ENV=production    # uncomment in deploy; production refuses to start
#                          without ADMIN_PASSWORD set (no dev fallback).

# HOST defaults to 127.0.0.1 — the analytics server is meant to sit behind
# a reverse proxy (Caddy) on the same host. Set HOST=0.0.0.0 only if you
# explicitly need direct external access; you almost never do.
# HOST=127.0.0.1
PORT=3000

# Admin Basic Auth.
# Set both before deploying. ADMIN_PASSWORD is intentionally left blank here
# so a careless `cp .env.example .env` does NOT inherit a real-looking
# default. Pick something long and unique.
ADMIN_USER=admin
ADMIN_PASSWORD=

# Site domain — fed into the daily-salted visitor_id hash as the stable site input.
SITE_DOMAIN=ilyadev.xyz

# SQLite file path — created on first boot if absent.
DB_PATH=./data/events.db
