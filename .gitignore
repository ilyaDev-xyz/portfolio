# OS
.DS_Store

# Node / Vite
node_modules/
dist/
dist-ssr/
*.local
.env
.env.*
!.env.example
.vite/

# TypeScript build cache
*.tsbuildinfo

# tsc -b emits .js next to source files. Vite serves the .ts directly,
# so emitted .js are dead artifacts that can shadow real source.
src/**/*.js

# Local private content and generated mirrors
src/content/.private/
src/content/active.ts
public/private/

# Generated by agent-mirrors Vite plugin (see vite.config.ts).
# Regenerated on every dev/build; treated as build artefacts.
public/index.md
public/index.ru.md
public/index.ar.md
public/index.txt
public/index.ru.txt
public/index.ar.txt
public/cases/*.md
public/cases/*.txt
public/llms.txt
public/llms-ru.txt
public/llms-ar.txt
public/llms-full.txt

# CV pipeline debug output (regenerated on `npm run cv:build`).
# PDFs land in public/private/ which is already ignored above.
scripts/cv/out/

# OG exporter scratch output. Public OG PNGs are committed under public/og*.
scripts/og/out/
